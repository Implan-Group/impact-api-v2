  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const ENV_VAR_KEYS = {\r",
          "  TokenUrl: \"tokenUrl\",\r",
          "  Username: \"username\",\r",
          "  Password: \"password\",\r",
          "  Token: \"bearerToken\",\r",
          "};\r",
          "\r",
          "const main = async () => {\r",
          "  if (!isTokenExpired()) {\r",
          "    console.log(\"Bypassing Bearer Token fetch because the stored token has not expired.\");\r",
          "    return;\r",
          "  }\r",
          "\r",
          "  console.log(\"Stored Bearer Token has expired, fetching a new token...\");\r",
          "  await fetchToken();\r",
          "};\r",
          "\r",
          "const getEnvVar = (key) => pm.environment.get(key);\r",
          "\r",
          "const setEnvVar = (key, val) => pm.environment.set(key, val);\r",
          "\r",
          "const isTokenExpired = () => {\r",
          "  const token = getEnvVar(ENV_VAR_KEYS.Token);\r",
          "\r",
          "  if (!token) return true;\r",
          "\r",
          "  const jwt = decodeToken(token);\r",
          "  console.log(\"Stored Bearer Token: \", jwt);\r",
          "  return Date.now() >= jwt.exp * 1000;\r",
          "};\r",
          "\r",
          "const decodeToken = (token) => JSON.parse(atob(token.split(\".\")[1]));\r",
          "\r",
          "const fetchToken = async () => {\r",
          "  try {\r",
          "    const response = await new Promise((resolve, reject) => {\r",
          "      pm.sendRequest(\r",
          "        {\r",
          "          url: getEnvVar(ENV_VAR_KEYS.TokenUrl),\r",
          "          method: \"POST\",\r",
          "          header: {\r",
          "            \"Content-Type\": \"application/json\",\r",
          "          },\r",
          "          body: {\r",
          "            mode: \"raw\",\r",
          "            raw: JSON.stringify({\r",
          "              username: getEnvVar(ENV_VAR_KEYS.Username),\r",
          "              password: getEnvVar(ENV_VAR_KEYS.Password),\r",
          "            }),\r",
          "          },\r",
          "        },\r",
          "        (err, response) =>\r",
          "          err || response.code < 200 || response.code >= 300\r",
          "            ? reject(err ?? response)\r",
          "            : resolve(response)\r",
          "      );\r",
          "    });\r",
          "\r",
          "    const newToken = response.text().replace('Bearer ', '');\r",
          "    console.log(\"New Bearer Token: \", decodeToken(newToken));\r",
          "    setEnvVar(ENV_VAR_KEYS.Token, newToken);\r",
          "  } catch (e) {\r",
          "    console.error(e);\r",
          "  }\r",
          "};\r",
          "\r",
          "main();"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
